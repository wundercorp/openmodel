{
  "name": "@wundercorp/openmodel",
  "version": "0.1.15",
  "description": "Download, run, and serve local AI models through a gateway-first CLI with OpenAI- and Ollama-compatible APIs.",
  "type": "module",
  "bin": {
    "om": "bin/om.mjs"
  },
  "exports": {
    ".": "./src/index.js",
    "./gateway-sdk": "./src/gateway-sdk.js"
  },
  "files": [
    "bin",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "check": "find src bin -name '*.js' -o -name '*.mjs' | xargs -n 1 node --check",
    "test": "node --test",
    "build": "node --check bin/om.mjs",
    "prepack": "node ../../scripts/validate-package-metadata.mjs . && node ../../scripts/verify-cli-release.mjs"
  },
  "dependencies": {
    "@wundercorp/openmodel-gateway-sdk": "0.1.1"
  },
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wundercorp/openmodel.git",
    "directory": "apps/cli"
  },
  "homepage": "https://openmodel.sh",
  "keywords": [
    "ai",
    "llm",
    "local-ai",
    "local-llm",
    "inference",
    "ollama",
    "llama.cpp",
    "gguf",
    "huggingface",
    "openai-compatible",
    "model-runtime",
    "model-gateway",
    "cli",
    "machine-learning"
  ],
  "author": {
    "name": "Wundercorp",
    "url": "https://wundercorp.co"
  },
  "bugs": {
    "url": "https://github.com/wundercorp/openmodel/issues"
  }
}
